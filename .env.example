# Banco de dados
DATABASE_URL=postgresql+asyncpg://veilsec:veilsec@localhost:5432/veilsec

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Principal (Camada 3)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=sk-your-key-here
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# Segurança (mínimo 32 chars)
OWNERSHIP_HMAC_SECRET=dev-secret-must-be-at-least-32-characters-long!!

# Storage (MinIO local em dev)
AWS_S3_BUCKET=veilsec-local
AWS_ENDPOINT_URL=http://localhost:9000
AWS_REGION=us-east-1

# Classificador IA (Camada 2)
AI_CLASSIFIER_MODE=mock
AI_CLASSIFIER_MODEL_PATH=./models/deberta-injection-detector

# Ambiente
ENVIRONMENT=development
VERSION=0.1.0

# LGPD
LGPD_CONSENT_VERSION=1.0
